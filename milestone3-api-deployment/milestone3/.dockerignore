# Ignore git records
.git
.gitignore

# Ignore python caching
**/__pycache__/
**/*.pyc
**/*.pyo
**/*.pyd

# Ignore local environment variables
.env
.env.*

# Ignore local data stores & Airflow DAGs
data/
dags/

# Ignore IDE settings & checkpoints
.vscode/
.idea/
.ipynb_checkpoints/

# Ignore local development scratch files
scratch/
inspect_model.py
test_prediction.py
